# --- App ---
APP_NAME=MenuMind
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://menumind:menumind@localhost:5432/menumind
POSTGRES_USER=menumind
POSTGRES_PASSWORD=menumind
POSTGRES_DB=menumind

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Pinecone ---
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=menumind

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=menumind-uploads

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Rate Limiting ---
RATE_LIMIT_CHAT_MESSAGES=30
RATE_LIMIT_WINDOW_SECONDS=60

# --- Logging ---
LOG_LEVEL=INFO
